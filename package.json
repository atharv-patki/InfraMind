{
  "name": "mocha-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "@hono/zod-validator": "^0.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "4.12.5",
    "lucide-react": "^0.510.0",
    "radix-ui": "^1.4.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "^7.5.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.12.0",
    "@eslint/js": "9.39.1",
    "@getmocha/users-service": "^0.0.4",
    "@getmocha/vite-plugins": "latest",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.14.1",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "5.1.4",
    "autoprefixer": "^10.4.21",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "15.15.0",
    "jsdom": "^28.1.0",
    "knip": "^5.51.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.0",
    "vite": "^7.1.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.33.0"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "db:migrate:local": "wrangler d1 migrations apply 019cb39f-b637-7f39-973d-e4c448663f3e --local",
    "db:migrate:remote": "wrangler d1 migrations apply 019cb39f-b637-7f39-973d-e4c448663f3e --remote",
    "db:seed:local": "wrangler d1 execute 019cb39f-b637-7f39-973d-e4c448663f3e --local --file db/seeds/001_demo_seed.sql",
    "cf-typegen": "wrangler types",
    "check": "tsc && vite build && wrangler deploy --dry-run",
    "dev": "vite",
    "knip": "knip",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run src/worker/integration src/worker/openapi src/worker/services",
    "test:worker": "vitest run src/worker",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck:app && npm run typecheck:worker",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:worker": "tsc --noEmit -p tsconfig.worker.json"
  }
}
